            "show_handle": false,
            "elements": []
        },
        "closer": {
            "scene_mode": "full-bleed",
            "text_position": "center",
            "text_align": "center",
            "gradient": { "direction": "full", "max_alpha_override": 180 },
            "logo": { "position": "bottom-right", "size_key": "content_size" },
